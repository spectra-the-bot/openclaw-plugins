{
  "private": true,
  "type": "module",
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format --diagnostic-level=error .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check": "biome check . && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.30.3"
}
