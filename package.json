{
  "private": true,
  "type": "module",
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format --diagnostic-level=error .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check": "biome check . && pnpm typecheck && pnpm test",
    "docs:dev": "vitepress dev docs",
    "predocs:build": "node scripts/render-mermaid.mjs --clean",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "changeset": "changeset",
    "changeset:version": "changeset version && pnpm biome format --write packages/*/package.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.27.12",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "vitepress": "^1.6.4"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.30.3"
}
