{
  "name": "@spectratools/sentinel",
  "version": "1.0.2",
  "description": "Secure declarative gateway-native watcher plugin for OpenClaw",
  "keywords": [
    "openclaw",
    "plugin",
    "security",
    "sentinel",
    "watcher"
  ],
  "homepage": "https://plugins.spectratools.dev/sentinel/",
  "bugs": {
    "url": "https://github.com/spectra-the-bot/openclaw-plugins/issues"
  },
  "license": "MIT",
  "author": "spectra",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spectra-the-bot/openclaw-plugins.git",
    "directory": "packages/sentinel-plugin"
  },
  "files": [
    "src",
    "schema",
    "openclaw.plugin.json"
  ],
  "type": "module",
  "scripts": {
    "prepack": "node ../../scripts/check-plugin-manifest.mjs --package .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.unit.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "ox": "^0.6.0",
    "re2-wasm": "^1.0.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.5.13",
    "ajv": "^8.17.1",
    "openclaw": "latest",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.2"
  },
  "optionalDependencies": {
    "re2": "^1.23.3"
  },
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "install": {
      "npmSpec": "@spectratools/sentinel",
      "defaultChoice": "npm"
    }
  }
}
