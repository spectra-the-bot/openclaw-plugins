{
  "name": "@spectratools/native-scheduler",
  "version": "1.3.1",
  "description": "Cross-platform native scheduler plugin for OpenClaw",
  "keywords": [
    "cron",
    "launchd",
    "openclaw",
    "plugin",
    "scheduler",
    "systemd",
    "windows-task-scheduler"
  ],
  "homepage": "https://plugins.spectratools.dev/native-scheduler/",
  "bugs": {
    "url": "https://github.com/spectra-the-bot/openclaw-plugins/issues"
  },
  "license": "MIT",
  "author": "spectra",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spectra-the-bot/openclaw-plugins.git",
    "directory": "packages/native-scheduler-plugin"
  },
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./index.ts"
    }
  },
  "files": [
    "index.ts",
    "src",
    "openclaw.plugin.json"
  ],
  "type": "module",
  "scripts": {
    "prepack": "node ../../scripts/check-plugin-manifest.mjs --package .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41",
    "@spectratools/native-scheduler-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "openclaw": "^2026.3.11",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@spectratools/native-scheduler",
      "defaultChoice": "npm"
    }
  }
}
